{
  "id": "com.flx.netatmo-community",
  "version": "2.0.1",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "platforms": ["local", "cloud"],
  "name": {
    "en": "Netatmo Community"
  },
  "description": {
    "en": "Comprehensive Netatmo Security integration for Homey Pro: rich flow cards for indoor & outdoor cameras and the video doorbell."
  },
  "category": ["security"],
  "brandColor": "#FF7A00",
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Felix",
    "email": "felix@flx.com"
  },

  "capabilities": {
    "light_mode": {
      "type": "enum",
      "title": { "en": "Floodlight" },
      "getable": true,
      "setable": true,
      "uiComponent": "picker",
      "values": [
        { "id": "on",   "title": { "en": "On" } },
        { "id": "off",  "title": { "en": "Off" } },
        { "id": "auto", "title": { "en": "Auto" } }
      ]
    },
    "siren_mode": {
      "type": "enum",
      "title": { "en": "Siren" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "values": [
        { "id": "no_sound",         "title": { "en": "Off" } },
        { "id": "warning",          "title": { "en": "Warning" } },
        { "id": "sound",            "title": { "en": "Alarm" } },
        { "id": "playing_record_0", "title": { "en": "Recording 1" } },
        { "id": "playing_record_1", "title": { "en": "Recording 2" } },
        { "id": "playing_record_2", "title": { "en": "Recording 3" } },
        { "id": "playing_record_3", "title": { "en": "Recording 4" } }
      ]
    }
  },

  "flow": {
    "triggers": [
      { "id": "motion_detected", "title": { "en": "Motion detected" }, "tokens": [
          { "name": "message", "type": "string", "title": { "en": "Message" } },
          { "name": "event_type", "type": "string", "title": { "en": "Event type" } }
        ], "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera|outdoor_camera|doorbell" }
        ]
      },
      { "id": "person_detected", "title": { "en": "A person is detected" }, "titleFormatted": { "en": "[[person]] was detected" }, "tokens": [
          { "name": "person_name", "type": "string", "title": { "en": "Person" } },
          { "name": "message", "type": "string", "title": { "en": "Message" } },
          { "name": "event_type", "type": "string", "title": { "en": "Event type" } }
        ], "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera" },
          { "name": "person", "type": "autocomplete", "title": { "en": "Person" } }
        ]
      },
      { "id": "unknown_person_detected", "title": { "en": "An unknown person is detected" }, "tokens": [
          { "name": "message", "type": "string", "title": { "en": "Message" } },
          { "name": "event_type", "type": "string", "title": { "en": "Event type" } }
        ], "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera" }
        ]
      },
      { "id": "person_left", "title": { "en": "Person left home" }, "titleFormatted": { "en": "[[person]] left home" }, "tokens": [
          { "name": "person_name", "type": "string", "title": { "en": "Person" } },
          { "name": "message", "type": "string", "title": { "en": "Message" } },
          { "name": "event_type", "type": "string", "title": { "en": "Event type" } }
        ], "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera" },
          { "name": "person", "type": "autocomplete", "title": { "en": "Person" } }
        ]
      },
      { "id": "person_came_home", "title": { "en": "Person came home" }, "titleFormatted": { "en": "[[person]] came home" }, "tokens": [
          { "name": "person_name", "type": "string", "title": { "en": "Person" } },
          { "name": "message", "type": "string", "title": { "en": "Message" } },
          { "name": "event_type", "type": "string", "title": { "en": "Event type" } }
        ], "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera" },
          { "name": "person", "type": "autocomplete", "title": { "en": "Person" } }
        ]
      },

      { "id": "human_detected", "title": { "en": "A human is detected" }, "tokens": [
          { "name": "message", "type": "string", "title": { "en": "Message" } },
          { "name": "event_type", "type": "string", "title": { "en": "Event type" } }
        ], "args": [
          { "name": "device", "type": "device", "filter": "driver_id=outdoor_camera" }
        ]
      },
      { "id": "vehicle_detected", "title": { "en": "A vehicle is detected" }, "tokens": [
          { "name": "message", "type": "string", "title": { "en": "Message" } },
          { "name": "event_type", "type": "string", "title": { "en": "Event type" } }
        ], "args": [
          { "name": "device", "type": "device", "filter": "driver_id=outdoor_camera" }
        ]
      },
      { "id": "animal_detected", "title": { "en": "An animal is detected" }, "tokens": [
          { "name": "message", "type": "string", "title": { "en": "Message" } },
          { "name": "event_type", "type": "string", "title": { "en": "Event type" } }
        ], "args": [
          { "name": "device", "type": "device", "filter": "driver_id=outdoor_camera" }
        ]
      },
      { "id": "siren_started", "title": { "en": "Siren started sounding" }, "args": [
          { "name": "device", "type": "device", "filter": "driver_id=outdoor_camera" }
        ]
      },
      { "id": "siren_stopped", "title": { "en": "Siren stopped sounding" }, "args": [
          { "name": "device", "type": "device", "filter": "driver_id=outdoor_camera" }
        ]
      },
      { "id": "floodlight_changed", "title": { "en": "Floodlight mode changed" }, "tokens": [
          { "name": "mode", "type": "string", "title": { "en": "Mode" } }
        ], "args": [
          { "name": "device", "type": "device", "filter": "driver_id=outdoor_camera" }
        ]
      },
      { "id": "daily_summary_ready", "title": { "en": "Daily summary available" }, "args": [
          { "name": "device", "type": "device", "filter": "driver_id=outdoor_camera" }
        ]
      },

      { "id": "doorbell_rang", "title": { "en": "Doorbell was pressed" }, "args": [
          { "name": "device", "type": "device", "filter": "driver_id=doorbell" }
        ]
      },
      { "id": "doorbell_call_accepted", "title": { "en": "Doorbell call was accepted" }, "args": [
          { "name": "device", "type": "device", "filter": "driver_id=doorbell" }
        ]
      },
      { "id": "doorbell_call_missed", "title": { "en": "Doorbell call was missed" }, "args": [
          { "name": "device", "type": "device", "filter": "driver_id=doorbell" }
        ]
      },

      { "id": "camera_connected", "title": { "en": "Camera came online" }, "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera|outdoor_camera|doorbell" }
        ]
      },
      { "id": "camera_disconnected", "title": { "en": "Camera went offline" }, "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera|outdoor_camera|doorbell" }
        ]
      },
      { "id": "monitoring_turned_on", "title": { "en": "Monitoring turned on" }, "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera|outdoor_camera" }
        ]
      },
      { "id": "monitoring_turned_off", "title": { "en": "Monitoring turned off" }, "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera|outdoor_camera" }
        ]
      }
    ],

    "conditions": [
      { "id": "is_monitoring_on",
        "title": { "en": "Monitoring !{{is|isn't}} on" },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera|outdoor_camera" }
        ]
      },
      { "id": "is_floodlight",
        "title": { "en": "Floodlight mode !{{is|isn't}} [[mode]]" },
        "titleFormatted": { "en": "Floodlight mode !{{is|isn't}} [[mode]]" },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=outdoor_camera" },
          { "name": "mode", "type": "dropdown", "values": [
            { "id": "on", "label": { "en": "On" } },
            { "id": "off", "label": { "en": "Off" } },
            { "id": "auto", "label": { "en": "Auto" } }
          ] }
        ]
      },
      { "id": "is_siren_sounding",
        "title": { "en": "Siren !{{is|isn't}} sounding" },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=outdoor_camera" }
        ]
      },
      { "id": "is_person_home",
        "title": { "en": "Person !{{is|isn't}} home" },
        "titleFormatted": { "en": "[[person]] !{{is|isn't}} home" },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera" },
          { "name": "person", "type": "autocomplete", "title": { "en": "Person" } }
        ]
      }
    ],

    "actions": [
      { "id": "turn_monitoring_on",
        "title": { "en": "Turn monitoring on" },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera|outdoor_camera" }
        ]
      },
      { "id": "turn_monitoring_off",
        "title": { "en": "Turn monitoring off" },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera|outdoor_camera" }
        ]
      },
      { "id": "set_floodlight_mode",
        "title": { "en": "Set floodlight to [[mode]]" },
        "titleFormatted": { "en": "Set floodlight to [[mode]]" },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=outdoor_camera" },
          { "name": "mode", "type": "dropdown", "values": [
            { "id": "on", "label": { "en": "On" } },
            { "id": "off", "label": { "en": "Off" } },
            { "id": "auto", "label": { "en": "Auto" } }
          ] }
        ]
      },
      { "id": "set_person_home",
        "title": { "en": "Mark person as home" },
        "titleFormatted": { "en": "Mark [[person]] as home" },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera" },
          { "name": "person", "type": "autocomplete", "title": { "en": "Person" } }
        ]
      },
      { "id": "set_person_away",
        "title": { "en": "Mark person as away" },
        "titleFormatted": { "en": "Mark [[person]] as away" },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera" },
          { "name": "person", "type": "autocomplete", "title": { "en": "Person" } }
        ]
      },
      { "id": "set_home_empty",
        "title": { "en": "Mark home as empty" },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera" }
        ]
      },
      { "id": "set_led_status",
        "title": { "en": "Set status LED to [[state]]" },
        "titleFormatted": { "en": "Set status LED to [[state]]" },
        "hint": { "en": "Turns the small status LED on the camera body on or off (does not affect the IR/night-vision LEDs)." },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera|outdoor_camera|doorbell" },
          { "name": "state", "type": "dropdown", "values": [
            { "id": "on", "label": { "en": "On" } },
            { "id": "off", "label": { "en": "Off" } }
          ] }
        ]
      },
      { "id": "set_notify_unknowns",
        "title": { "en": "Set unknown-face notifications to [[state]]" },
        "titleFormatted": { "en": "Set unknown-face notifications to [[state]]" },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera" },
          { "name": "state", "type": "dropdown", "values": [
            { "id": "on", "label": { "en": "On" } },
            { "id": "off", "label": { "en": "Off" } }
          ] }
        ]
      },
      { "id": "set_record_when_unknown",
        "title": { "en": "Set recording on unknown face to [[state]]" },
        "titleFormatted": { "en": "Set recording on unknown face to [[state]]" },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=indoor_camera" },
          { "name": "state", "type": "dropdown", "values": [
            { "id": "on", "label": { "en": "On" } },
            { "id": "off", "label": { "en": "Off" } }
          ] }
        ]
      }
    ]
  },

  "drivers": [
    {
      "id": "indoor_camera",
      "name": { "en": "Smart Indoor Camera" },
      "class": "camera",
      "capabilities": ["onoff", "alarm_motion"],
      "capabilitiesOptions": {
        "onoff": {
          "title": { "en": "Monitoring" },
          "insightsTitleTrue": { "en": "Monitoring turned on" },
          "insightsTitleFalse": { "en": "Monitoring turned off" }
        }
      },
      "platforms": ["local", "cloud"],
      "connectivity": ["cloud"],
      "images": {
        "small": "/drivers/indoor_camera/assets/images/small.png",
        "large": "/drivers/indoor_camera/assets/images/large.png",
        "xlarge": "/drivers/indoor_camera/assets/images/xlarge.png"
      },
      "pair": [
        { "id": "login_oauth2", "template": "login_oauth2" },
        { "id": "list_devices", "template": "list_devices", "navigation": { "next": "add_devices" } },
        { "id": "add_devices", "template": "add_devices" }
      ]
    },
    {
      "id": "outdoor_camera",
      "name": { "en": "Smart Outdoor Camera" },
      "class": "camera",
      "capabilities": ["onoff", "alarm_motion", "light_mode", "siren_mode"],
      "capabilitiesOptions": {
        "onoff": {
          "title": { "en": "Monitoring" },
          "insightsTitleTrue": { "en": "Monitoring turned on" },
          "insightsTitleFalse": { "en": "Monitoring turned off" }
        }
      },
      "platforms": ["local", "cloud"],
      "connectivity": ["cloud"],
      "images": {
        "small": "/drivers/outdoor_camera/assets/images/small.png",
        "large": "/drivers/outdoor_camera/assets/images/large.png",
        "xlarge": "/drivers/outdoor_camera/assets/images/xlarge.png"
      },
      "pair": [
        { "id": "login_oauth2", "template": "login_oauth2" },
        { "id": "list_devices", "template": "list_devices", "navigation": { "next": "add_devices" } },
        { "id": "add_devices", "template": "add_devices" }
      ]
    },
    {
      "id": "doorbell",
      "name": { "en": "Smart Video Doorbell" },
      "class": "doorbell",
      "capabilities": ["alarm_generic"],
      "capabilitiesOptions": {
        "alarm_generic": {
          "title": { "en": "Doorbell pressed" }
        }
      },
      "platforms": ["local", "cloud"],
      "connectivity": ["cloud"],
      "images": {
        "small": "/drivers/doorbell/assets/images/small.png",
        "large": "/drivers/doorbell/assets/images/large.png",
        "xlarge": "/drivers/doorbell/assets/images/xlarge.png"
      },
      "pair": [
        { "id": "login_oauth2", "template": "login_oauth2" },
        { "id": "list_devices", "template": "list_devices", "navigation": { "next": "add_devices" } },
        { "id": "add_devices", "template": "add_devices" }
      ]
    }
  ]
}
